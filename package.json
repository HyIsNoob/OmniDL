{
  "name": "omnidl",
  "version": "1.4.0",
  "description": "OmniDL — YouTube, TikTok & Facebook downloader",
  "main": "out/main/index.js",
  "type": "module",
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/HyIsNoob/OmniDL.git"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "lint": "eslint .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder --publish never",
    "release": "npm run build && electron-builder --publish always",
    "changelog:extract": "node scripts/extract-changelog.mjs"
  },
  "dependencies": {
    "@fontsource/archivo-black": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "electron-updater": "^6.3.9",
    "ffmpeg-static": "^5.2.0",
    "lucide-react": "^1.7.0",
    "sql.js": "^1.12.0"
  },
  "build": {
    "appId": "com.omnidl.app",
    "productName": "OmniDL",
    "icon": "icon.png",
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": "favicon.ico",
        "to": "favicon.ico"
      }
    ],
    "files": [
      "out/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**/*",
      "**/node_modules/sql.js/dist/sql-wasm.wasm"
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "HyIsNoob",
        "repo": "OmniDL"
      }
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "eslint": "^9.16.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "framer-motion": "^11.15.0",
    "globals": "^15.14.0",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.16",
    "typescript": "~5.6.3",
    "typescript-eslint": "^8.18.1",
    "vite": "^5.4.11",
    "zustand": "^5.0.2"
  }
}
